# Copy to .env.production — prod values for Cloudflare / wrangler secret bulk
# cp .env.production.example .env.production
# Then: cd apps/web && npx wrangler secret bulk ../../.env.production.secrets
# Or set each in Cloudflare dashboard → Workers → seedance-web → Settings → Variables

# Clerk (production instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_
CLERK_WEBHOOK_SECRET=whsec_

# Dodo Payments (live) — API key + webhook secret from Dashboard → Developer
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENV=live
DODO_WEBHOOK_SECRET=
# Single pay-what-you-want product; packs are UI presets that set amount (cents)
DODO_TOPUP_PRODUCT_ID=pdt_

# App
NEXT_PUBLIC_APP_URL=https://seedanceapi.us
NEXT_PUBLIC_DOCS_URL=https://seedanceapi.us/docs

# Webhook URLs (configure in provider dashboards, not env vars):
# Clerk:  https://seedanceapi.us/api/webhooks/clerk
# Dodo:   https://seedanceapi.us/api/webhooks/dodo
