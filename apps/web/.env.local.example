# Copy to .env.local for local Next.js dev (pnpm dev:web)
# cp .env.local.example .env.local

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Dummy for local dev — verification skipped when NODE_ENV !== production
# Use real whsec_... only if testing webhooks via ngrok/cloudflared
CLERK_WEBHOOK_SECRET=whsec_dev_dummy

# Dodo Payments — https://dodopayments.com
# Leave API key empty (or set DODO_DEV_CREDIT=true) to credit the wallet instantly in local dev.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENV=test
DODO_WEBHOOK_SECRET=dodo_dev_dummy
# DODO_DEV_CREDIT=true
# Single pay-what-you-want product; packs are UI presets that set amount (cents).
# DODO_TOPUP_PRODUCT_ID=pdt_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_DOCS_URL=http://localhost:3333
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=http://localhost:3000/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=http://localhost:3000/dashboard

# PostHog (optional)
# NEXT_PUBLIC_POSTHOG_KEY=phc_
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_API_KEY=phc_

# Optional: force webhook signature verification in dev (e.g. ngrok + real secrets)
# WEBHOOK_VERIFY=true
