{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "seedance-web",
  "main": "worker.js",
  "account_id": "9c8c17cfa5b8c29c830e072acce42a3d",
  "compatibility_date": "2025-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "seedance-db",
      "database_id": "3e049b4b-c528-441e-992b-363a468ade9a"
    }
  ],
  "vars": {
    "API_BASE_URL": "https://api.seedanceapi.us",
    "CUSTOM_DOMAIN": "seedanceapi.us",
    "MINTLIFY_DOCS_HOST": "seedanceus.mintlify.site"
  },
  "routes": [
    {
      "pattern": "seedanceapi.us",
      "custom_domain": true
    }
  ]
}
