{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SeedanceAPI",
  "description": "REST API for SeedDance video and Seedream image generation.",
  "colors": {
    "primary": "#2563eb",
    "light": "#3b82f6",
    "dark": "#1d4ed8"
  },
  "background": {
    "color": {
      "light": "#fafaf9",
      "dark": "#0c0e14"
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://seedanceapi.us"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "Models",
        "href": "https://seedanceapi.us/models"
      },
      {
        "label": "Pricing",
        "href": "https://seedanceapi.us/pricing"
      },
      {
        "label": "For Agents",
        "href": "https://seedanceapi.us/agents"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://seedanceapi.us/dashboard"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Website", "href": "https://seedanceapi.us" },
          { "label": "Models", "href": "https://seedanceapi.us/models" },
          { "label": "Pricing", "href": "https://seedanceapi.us/pricing" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "OpenAPI", "href": "https://api.seedanceapi.us/openapi.json" },
          { "label": "llms.txt", "href": "https://seedanceapi.us/llms.txt" },
          { "label": "MCP", "href": "https://seedanceapi.us/agents" }
        ]
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Guides",
            "pages": ["videos", "images", "media", "models", "errors", "agents"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi.json",
            "pages": [
              "GET /health",
              "GET /v1/models",
              "GET /v1/credits",
              "POST /v1/media/upload",
              "POST /v1/videos",
              "POST /v1/images",
              "GET /v1/generations/{id}"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "javascript", "python"]
    },
    "mdx": {
      "server": "https://api.seedanceapi.us",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "mcp"
    ],
    "display": "header"
  }
}
